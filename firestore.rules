rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }
    function isAuthorizedAdminEmail() {
      return isAuthenticated() && (request.auth.token.email == 'instructor@inclusiveed.org' || request.auth.token.email == 'kwbnbassaw@gmail.com');
    }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isRole(role) { return isAuthenticated() && getUserData().role == role; }
    function isAdmin() { return isAuthorizedAdminEmail() || isRole('ADMIN'); }
    function isInstructor() { return isRole('INSTRUCTOR'); }
    function isStudent() { return isRole('STUDENT'); }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow users to update their profile, but NOT their role unless they are an admin
      allow update: if (request.auth.uid == userId && (request.resource.data.role == resource.data.role || isAuthorizedAdminEmail())) || isAdmin();
      allow create: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();

      match /{document=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isInstructor() && resource.data.instructorId == request.auth.uid) || (isInstructor() && request.method == 'create');
    }
    match /modules/{moduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /contents/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /aiQuizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /aiWeeks/{weekId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /calendarEvents/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /invites/{inviteId} {
      allow read: if true;
      allow write: if isAdmin() || isInstructor() || (isAuthenticated() && request.resource.data.status == "USED");
    }
    match /mail/{mailId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || isInstructor();
    }
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if (isStudent() && resource.data.studentId == request.auth.uid) || isAdmin() || isInstructor();
      allow delete: if isAdmin() || isInstructor();
    }
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
    }
    match /assignmentSubmissions/{submissionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || isInstructor() || isAdmin());
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin() || isInstructor();
    }
    match /quizSubmissions/{submissionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || isInstructor() || isAdmin());
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin() || isInstructor();
    }
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.recipientId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.recipientId;
      allow write: if isAdmin() || isInstructor();
    }
    match /fcmTokens/{tokenId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    match /chat_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == request.resource.data.studentId);
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }
    match /user_activity/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    match /course_discussions/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isInstructor();
      
      match /threads/{threadId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin() || isInstructor());
      }
    }
  }
}
